# runtime artefacts (логи мониторинга и отчёты — генерируются при работе)
data/runtime/*.jsonl
data/runtime/*.json
!data/runtime/.gitkeep
data/runtime/snapshots/*.json
!data/runtime/snapshots/.gitkeep
