# ─── GigaChat (LLM-слой ассистента) ──────────────────────────────────────────
# Ключ авторизации проекта GigaChat API (Base64 от "client_id:client_secret").
# Берётся в личном кабинете developers.sber.ru. Если не задан — ассистент работает
# в офлайн-режиме (детерминированное ядро + шаблонные объяснения), демо остаётся
# полностью функциональным.
GIGACHAT_CREDENTIALS=

# Версия API: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель генерации. По умолчанию — наиболее сильная из доступных.
GIGACHAT_MODEL=GigaChat-2-Max

# Проверять TLS-сертификаты Минцифры РФ. Для локального запуска обычно false.
GIGACHAT_VERIFY_SSL=false

# Температура генерации объяснений (низкая → меньше галлюцинаций).
GIGACHAT_TEMPERATURE=0.2

# ─── Поведение ассистента ────────────────────────────────────────────────────
# Принудительно отключить LLM-слой (только детерминированное ядро).
ASSISTANT_LLM_DISABLED=false

# Порог свежести каталога вкладов (дней). Старше — баннер деградации.
CATALOG_FRESHNESS_SLA_DAYS=14
